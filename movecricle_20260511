Public Class FormBallGame

    Private Sub TextHunt_TextChanged(sender As Object, e As EventArgs) Handles TextHunt.TextChanged
        ' テキストが変更されたときの処理（必要に応じて記述）
    End Sub

    Private Sub DrawCircleSelectPictureBox()

        Dim height As Integer = SelectPictureBox.Height
        Dim width As Integer = SelectPictureBox.Width

        ' 1. 古い画像がすでにPictureBoxにある場合は、メモリ解放（Dispose）する
        If SelectPictureBox.Image IsNot評 AndAlso SelectPictureBox.Image IsNot Nothing Then
            SelectPictureBox.Image.Dispose()
        End If

        ' 2. 新しいキャンバスを作成
        Dim selectCanvas As New Bitmap(width, height)

        ' 3. キャンバスに描画
        Using g As Graphics = Graphics.FromImage(selectCanvas)
            ' 水色の円を描画
            g.FillEllipse(Brushes.LightBlue, 0, 0, height, height)
        End Using ' ここで g（Graphics）は安全に解放されます

        ' 4. 作成した画像をPictureBoxに表示
        SelectPictureBox.Image = selectCanvas

    End Sub

End Class ' ← 改行して正しく閉じます

