Public Class FormUranai

    Private Sub Button1_Click(sender As Object, e As EventArgs) Handles Button1.Click

        Dim number As Integer

        number = DateTimeUranai.Value.DayOfYear

        Select Case number Mod 5

            Case 0
                PictureBox1.Image = My.Resources.Daikichi
                TextResult.Text = "大吉です！"

            Case 1
                PictureBox1.Image = My.Resources.Chukichi
                TextResult.Text = "中吉です！"

            Case 2
                PictureBox1.Image = My.Resources.Shokichi
                TextResult.Text = "小吉です！"

            Case 3
                PictureBox1.Image = My.Resources.Kichi
                TextResult.Text = "吉です！"

            Case 4
                PictureBox1.Image = My.Resources.Kyo
                TextResult.Text = "凶です！"

            Case Else
                PictureBox1.Image = Nothing
                TextResult.Text = ""

        End Select

    End Sub

