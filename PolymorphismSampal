
Public Class Animal

    ' すべての動物クッキーに
    ' 共通している値を定義

    ' 色のプロパティ
    Public Property Color As String = "茶"

    ' 匂いのプロパティ
    Public Property Smell As String = "コーヒー"

    ' 味のプロパティ
    Public Property Flavor As String = "チョコレート"

    ' 動物の鳴き声
    Public Overridable Function Sing() As Image

        Return My.Resources.AnimalCookieSing

    End Function

    ' クッキー画像
    Public Overridable Function Reset() As Image

        Return My.Resources.AnimalCookie

    End Function

End Class


Public Class Dog

    ' Inherit from the Animal class
    Inherits Animal

    ' Nose shape
    Public Property Nose As String = ""

    ' Dog singing image
    Public Overrides Function Sing() As Image

        Return My.Resources.DogCookieSing

    End Function

    ' Dog normal image
    Public Overrides Function Reset() As Image

        Return My.Resources.DogCookie

    End Function

End Class


Public Class Cat

    ' Inherit from the Animal class
    Inherits Animal

    ' Ear shape
    Public Property Ear As String = "Round"

    ' Cat singing image
    Public Overrides Function Sing() As Image

        Return My.Resources.CatCookieSing

    End Function

    ' Cat normal image
    Public Overrides Function Reset() As Image

        Return My.Resources.CatCookie

    End Function

End Class


Public Class Bird

    ' Inherit from the Animal class
    Inherits Animal

    ' Shape of the beak
    Public Property Beak As String = "Triangle"

    ' Bird singing image
    Public Overrides Function Sing() As Image

        Return My.Resources.BirdCookieSing

    End Function

    ' Bird normal image
    Public Overrides Function Reset() As Image

        Return My.Resources.BirdCookie

    End Function

End Class
