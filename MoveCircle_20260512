Public Class Ball
    Private Const radius As Integer = 40
    Public position As New Point(0, 0)
    Private direction As New Point(1, 1)
    Public Property Pitch As Integer = 8

    Private ReadOnly kanji As String
    Private ReadOnly brushColor As Brush
    Private ReadOnly pictureBox As PictureBox
    Private ReadOnly canvas As Bitmap
    Private ReadOnly fontName As String

    ' コンストラクタ
    Public Sub New(pb As PictureBox, cv As Bitmap, cl As Brush, st As String, fn As String)
        pictureBox = pb
        canvas = cv
        brushColor = cl
        kanji = st
        fontName = fn

        ' 初期の向きをランダムに設定
        Dim r As New Random()
        direction.X = If(r.Next(0, 2) = 0, 1, -1)
        direction.Y = If(r.Next(0, 2) = 0, 1, -1)
    End Sub

    ' 初期配置
    Public Sub PutCircle(x As Integer, y As Integer)
        position.X = x
        position.Y = y
        Draw()
    End Sub

    ' 描画処理
    Private Sub Draw()
        Using g As Graphics = Graphics.FromImage(canvas)
            g.SmoothingMode = Drawing2D.SmoothingMode.AntiAlias
            ' 円を描く
            g.FillEllipse(brushColor, position.X, position.Y, radius * 2, radius * 2)
            ' 文字を描く
            Using f As New Font(fontName, 25, FontStyle.Bold)
                g.DrawString(kanji, f, Brushes.Black, position.X + 15, position.Y + 15)
            End Using
        End Using
    End Sub

    ' 移動処理
    Public Sub Move()
        position.X += Pitch * direction.X
        position.Y += Pitch * direction.Y

        ' 壁の跳ね返り判定
        If position.X >= pictureBox.Width - radius * 2 OrElse position.X <= 0 Then
            direction.X *= -1
        End If
        If position.Y >= pictureBox.Height - radius * 2 OrElse position.Y <= 0 Then
            direction.Y *= -1
        End If

        Draw()
    End Sub
End Class
