Public Class FormBallGame
    Private canvas As Bitmap
    Private balls As New List(Of Ball)
    Private rnd As New Random()

    ' 正解と間違いの漢字
    Private Const correctText As String = "獲"
    Private Const mistakeText As String = "僕"

    ' フォームロード時の処理
    Private Sub FormBallGame_Load(sender As Object, e As EventArgs) Handles MyBase.Load
        ' コントロールの初期設定
        TextHunt.Text = correctText
        TextTimerS.Text = "30"

        ' ゲームエリア（キャンバス）の初期化
        InitCanvas()

        ' 見本（SelectPictureBox）の描画
        DrawSelectTarget()

        ' ボールの生成
        CreateBalls()

        ' タイマー開始
        Timer1.Interval = 20
        Timer1.Start()
    End Sub

    ' キャンバスの初期化
    Private Sub InitCanvas()
        If canvas IsNot Nothing Then canvas.Dispose()
        canvas = New Bitmap(MainpictureBox.Width, MainpictureBox.Height)
        MainpictureBox.Image = canvas
    End Sub

    ' 見本エリアの描画
    Private Sub DrawSelectTarget()
        Dim selectCanvas = New Bitmap(SelectPictureBox.Width, SelectPictureBox.Height)
        Using g = Graphics.FromImage(selectCanvas)
            g.Clear(Color.White)
            g.SmoothingMode = Drawing2D.SmoothingMode.AntiAlias
            ' 見本用の青い円を描く
            g.FillEllipse(Brushes.LightBlue, 10, 5, 40, 40)
            ' 見本用の文字を描く
            Using f As New Font(Me.Font.Name, 20)
                g.DrawString(correctText, f, Brushes.Black, 15, 10)
            End Using
        End Using
        SelectPictureBox.Image = selectCanvas
    End Sub

    ' ボールの作成
    Private Sub CreateBalls()
        balls.Clear()
        Dim colors As Brush() = {Brushes.LightBlue, Brushes.LightPink, Brushes.LightGray, Brushes.LightCoral, Brushes.LightGreen}

        ' ランダムに正解を1つ決める
        Dim winIndex As Integer = rnd.Next(0, 5)

        For i As Integer = 0 To 4
            Dim txt As String = If(i = winIndex, correctText, mistakeText)
            Dim b As New Ball(MainpictureBox, canvas, colors(i Mod colors.Length), txt, Me.Font.Name)

            ' ランダムな初期位置
            Dim startX As Integer = rnd.Next(0, Math.Max(1, MainpictureBox.Width - 100))
            Dim startY As Integer = rnd.Next(0, Math.Max(1, MainpictureBox.Height - 100))
            b.PutCircle(startX, startY)

            balls.Add(b)
        Next
    End Sub

    ' タイマーごとの更新処理
    Private Sub Timer1_Tick(sender As Object, e As EventArgs) Handles Timer1.Tick
        Using g As Graphics = Graphics.FromImage(canvas)
            g.Clear(Color.White) ' 画面を白でリセット
            For Each b In balls
                b.Move()
            Next
        End Using
        MainpictureBox.Invalidate() ' 画面を更新
    End Sub

    ' 再スタートボタン
    Private Sub RestartButtom_Click(sender As Object, e As EventArgs) Handles RestartButtom.Click
        Timer1.Stop()
        InitCanvas()
        CreateBalls()
        Timer1.Start()
    End Sub

    ' 下のエントリをクリックした時の処理
    Private Sub MainpictureBox_MouseClick(sender As Object, e As MouseEventArgs) Handles MainpictureBox.MouseClick
        ' クリックで位置を変える演出
        CreateBalls()
    End Sub
End Class

